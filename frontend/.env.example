# Frontend environment variables for development
# Copy this file to .env and customize values as needed for local development.

# Vite dev proxy target for API requests 
VITE_API_TARGET=http://localhost:8080

# Port Vite dev server runs on 
VITE_DEV_PORT=5173

# Playwright base URL for E2E tests
PW_BASE_URL=http://localhost:5173

# Optional: toggles MSW mocking in the app
VITE_ENABLE_MSW=false
