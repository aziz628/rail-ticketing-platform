# Environment file for automated tests
# Copy values into .env.example.test when running tests .

# Point to test backend or mock server if needed
VITE_API_TARGET=http://localhost:8080

# Playwright base URL used by tests
PW_BASE_URL=http://localhost:5173

# Ensure MSW mocking is enabled for tests (if using MSW)
VITE_ENABLE_MSW=true
