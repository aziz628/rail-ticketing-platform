spring.application.name=railticket

# Server
server.port=8080
server.servlet.context-path=/api

# PostgreSQL
# host-dev: postgres runs in Docker, exposed on localhost:5432
# full Docker: env vars from docker-compose override these
spring.datasource.url=jdbc:postgresql://localhost:5432/railticket
spring.datasource.username=admin
spring.datasource.password=admin
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=validate

# Flyway
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration

# Redis
# host-dev: redis runs in Docker, exposed on localhost:6379
# full Docker: env vars from docker-compose override these
spring.data.redis.host=localhost
spring.data.redis.port=6379

# JPA
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# Logging
#root is the default level for all loggers
logging.level.root=WARN
#app package represents our application code, we want to see INFO logs from it
logging.level.com.sncft.app=INFO 
# Spring Boot's internal logs can be very verbose, so we set it to WARN to reduce noise
logging.level.org.springframework.boot=WARN 

# Session
# Browser auth is carried by the HTTP session cookie; keep it long enough for dev and demo flows.
server.servlet.session.timeout=8h

# Mailtrap / SMTP
spring.mail.host=sandbox.smtp.mailtrap.io
spring.mail.port=2525
spring.mail.username=your_mailtrap_username
spring.mail.password=your_mailtrap_password
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

